# OPERATOR: this is the unencrypted template for the unpoller UniFi
# API key secret. Claude does NOT author the encrypted file. To finish
# wiring this branch:
#
#   1. Replace REPLACE_ME with the UniFi API key. Create the key via:
#         UniFi Network → Settings → Control Plane → Admins & Users
#         → Create API Key
#      with read-only role.
#   2. Rename the file:
#         mv secret.sops.yaml.example secret.sops.yaml
#   3. Encrypt in place:
#         sops -e -i infra/controllers/unpoller/secret.sops.yaml
#   4. Commit & push to this branch (feat/unpoller-phase9).
#
# `.sops.yaml` at the repo root already covers `infra/.*secret.*\.yaml$`
# so no rule changes are needed.
#
# The HelmRelease references this secret via:
#   envVariables[0].valueFrom.secretKeyRef.name = unpoller-unifi-creds
#   envVariables[0].valueFrom.secretKeyRef.key  = api_key
# Keep both `metadata.name` and the `api_key` key intact.
apiVersion: v1
kind: Secret
metadata:
  name: unpoller-unifi-creds
  namespace: monitoring
type: Opaque
stringData:
  api_key: REPLACE_ME
