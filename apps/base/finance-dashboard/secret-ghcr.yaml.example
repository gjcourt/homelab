# TEMPLATE — operator-only. ghcr.io image-pull secret for the PRIVATE
# gjcourt/finance-dashboard image. The deployment references it as `ghcr-secret`.
#
# Easiest way to create the real, encrypted secret (you run this — needs a ghcr
# PAT with read:packages scope in $GHCR_PAT):
#
#   kubectl create secret docker-registry ghcr-secret \
#     --docker-server=ghcr.io \
#     --docker-username=gjcourt \
#     --docker-password="$GHCR_PAT" \
#     --namespace=finance-dashboard \
#     --dry-run=client -o yaml \
#     > apps/base/finance-dashboard/secret-ghcr.yaml
#   sops -e -i apps/base/finance-dashboard/secret-ghcr.yaml
#
# The .sops.yaml "*secret*.yaml" rule encrypts the .dockerconfigjson data field.
# Never commit an unencrypted secret-ghcr.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-secret
  namespace: finance-dashboard
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: REPLACE_ME_BASE64_DOCKERCONFIGJSON
