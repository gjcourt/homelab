# TEMPLATE — operator-only. The consolidated data secret for the finance site:
# positions / cashflow / str / runway / candidates, each a key under stringData,
# mounted at /data. Easiest path is the helper (builds + encrypts from your
# local source YAMLs in ~/src/utility/portfolio):
#
#   scripts/update-finance-data.sh        # run from the homelab repo root
#   git add apps/base/finance-dashboard/secret-finance-data.yaml && git commit ...
#
# The .sops.yaml "*secret*.yaml" rule encrypts the stringData field. Never commit
# an unencrypted secret-finance-data.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: finance-dashboard-data
  namespace: finance-dashboard
  labels:
    app: finance-dashboard
type: Opaque
stringData:
  positions.yaml: |
    # >>> contents of positions.yaml (balance sheet) <<<
  cashflow.yaml: |
    # >>> contents of cashflow.yaml (cash-flow model inputs) <<<
  str.yaml: |
    # >>> contents of str.yaml (STR pro-forma defaults) <<<
  runway.yaml: |
    # >>> contents of runway.yaml (retirement-runway inputs) <<<
  candidates.yaml: |
    # >>> contents of candidates.yaml (redfin_filter.py --emit-yaml) <<<
