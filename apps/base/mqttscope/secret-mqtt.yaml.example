# TEMPLATE — operator-only. Broker credentials for the mqttscope exporter.
# The Deployment consumes these two keys via envFrom (MQTT_USERNAME /
# MQTT_PASSWORD).
#
# IMPORTANT — a DEDICATED broker user is required. The existing mmwave /
# espresense / zigbee2mqtt users are ACL-scoped to their own topic trees
# (e.g. mmwave -> `mmwave/#` + `homeassistant/#`) and CANNOT read `$SYS/#`.
# mqttscope needs read on `$SYS/#` and readwrite on `mqttscope/#` for the
# round-trip probe. Reusing mmwave will NOT work once acl_file is enabled.
#
# Operator prerequisites (all in infra/controllers/mosquitto/, SOPS-encrypted):
#   1. Add an `mqttscope` user to the mosquitto passwordfile:
#        docker run --rm -it eclipse-mosquitto sh -c '
#          mosquitto_passwd -b /tmp/pw mqttscope <pass> && cat /tmp/pw'
#      append that line to `passwordfile` in secret-mqtt-auth.yaml.
#   2. Add its ACL block to the `acl` field in secret-mqtt-auth.yaml:
#        user mqttscope
#        topic read $SYS/#
#        topic readwrite mqttscope/#
#   3. Re-encrypt: sops -e -i infra/controllers/mosquitto/secret-mqtt-auth.yaml
#
# Then create THIS secret (the exporter side):
#   1. cp secret-mqtt.yaml.example secret-mqtt.yaml
#   2. fill in the username/password below (the same <pass> from step 1)
#   3. sops -e -i apps/base/mqttscope/secret-mqtt.yaml
#   4. add `secret-mqtt.yaml` to kustomization.yaml resources (already
#      referenced there — kustomize build / CI fails until the real file
#      exists, which is the intended gate).
#
# The .sops.yaml "*secret*.yaml" rule encrypts stringData. Never commit an
# unencrypted secret-mqtt.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: mqttscope-mqtt
  namespace: mqttscope
  labels:
    app.kubernetes.io/name: mqttscope
type: Opaque
stringData:
  MQTT_USERNAME: mqttscope
  MQTT_PASSWORD: REPLACE_WITH_MQTTSCOPE_BROKER_PASSWORD
