# Template for the flashcards-db staging CNPG bootstrap credentials secret.
#
# Steps for the operator:
#   1. Generate a random password (e.g. `openssl rand -base64 32 | tr -d '/+='`).
#      Use a DIFFERENT password from production.
#   2. Replace REPLACE_ME_WITH_RANDOM_PASSWORD below with the generated value.
#   3. Save the file as `secret-db-credentials.yaml` (drop the `.example` suffix).
#   4. Encrypt in place: `sops -e -i apps/staging/flashcards-sync/secret-db-credentials.yaml`.
#   5. Uncomment the `- secret-db-credentials.yaml` line in this directory's
#      `kustomization.yaml`.
apiVersion: v1
kind: Secret
metadata:
  name: flashcards-db-credentials
  namespace: flashcards-stage
  labels:
    app: flashcards-sync
    env: staging
type: kubernetes.io/basic-auth
stringData:
  username: app
  password: REPLACE_ME_WITH_RANDOM_PASSWORD
