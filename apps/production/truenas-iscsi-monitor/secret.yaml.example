# Template — copy to secret.yaml and SOPS-encrypt before merging.
#
# How to populate:
#   1. Create a dedicated read-only API key in the TrueNAS UI
#      (Settings -> API Keys -> Add). Save the token.
#   2. Copy this file: `cp secret.yaml.example secret.yaml`.
#   3. Replace REPLACE_WITH_TRUENAS_API_KEY in secret.yaml with the token.
#   4. Encrypt: `sops -e -i secret.yaml`.
#   5. Verify: `sops -d secret.yaml | grep -v ENC` shows the plaintext you
#      just put in (then `git status` should still show secret.yaml as
#      modified — encrypted form).
#   6. Commit only the encrypted form.
#
# Reference for the .sops.yaml age recipient + format:
# `apps/production/synology-iscsi-monitor/secret.yaml`.
apiVersion: v1
kind: Secret
metadata:
  name: truenas-iscsi-monitor-secret
  namespace: truenas-iscsi-monitor
type: Opaque
stringData:
  api_key: REPLACE_WITH_TRUENAS_API_KEY
