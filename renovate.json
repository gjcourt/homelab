{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "kubernetes": {
    "fileMatch": [
      "\\.yaml$"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "digest",
        "pin",
        "patch",
        "minor",
        "major"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    }
  ]
}
