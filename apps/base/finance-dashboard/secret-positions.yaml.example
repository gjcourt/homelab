# TEMPLATE — operator-only. Creates the Secret that feeds positions.yaml into
# the dashboard pod (mounted at /data/positions.yaml).
#
# To activate (you run this — SOPS edits are operator-only):
#   cd ~/src/homelab/.worktrees/finance-dashboard   # or wherever this lands
#   cp apps/base/finance-dashboard/secret-positions.yaml.example \
#      apps/base/finance-dashboard/secret-positions.yaml
#   # paste the real contents of ~/src/utility/portfolio/positions.yaml under the
#   # "positions.yaml: |" key below (keep the indentation), then:
#   sops -e -i apps/base/finance-dashboard/secret-positions.yaml
#
# The .sops.yaml "*secret*.yaml" rule encrypts the stringData field; the plaintext
# numbers then exist only inside the running pod. Do NOT commit this .example with
# real values, and do NOT commit an unencrypted secret-positions.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: finance-dashboard-positions
  namespace: finance-dashboard
  labels:
    app: finance-dashboard
type: Opaque
stringData:
  positions.yaml: |
    # >>> Replace this entire block with your real positions.yaml contents <<<
    ips:
      target_allocation:
        equity: 0.65
        fixed_income: 0.20
        cash: 0.15
      reserve_usd: 500000
      fi_target_usd: 10000000
    positions:
      - name: EXAMPLE_INDEX
        bucket: liquid
        asset_class: equity
        value_usd: 0
        institution: PLACEHOLDER
        source: manual
