# Template for the flashcards-db CNPG bootstrap credentials secret.
#
# Steps for the operator:
#   1. Generate a random password (e.g. `openssl rand -base64 32 | tr -d '/+='`).
#   2. Replace REPLACE_ME_WITH_RANDOM_PASSWORD below with the generated value.
#   3. Save the file as `secret-db-credentials.yaml` (drop the `.example` suffix).
#   4. Encrypt in place: `sops -e -i apps/production/flashcards-sync/secret-db-credentials.yaml`.
#   5. Add the encrypted file to `apps/production/flashcards-sync/kustomization.yaml`
#      under `resources:` (already listed there — uncomment when ready).
#   6. Commit with a non-secret-related conventional commit message.
#
# CNPG `bootstrap.initdb` consumes `username`/`password` keys to create the
# `app` user that owns the `app` database on first cluster init. After init,
# the sync service Deployment reads `password` via secretKeyRef to build
# DATABASE_URL.
apiVersion: v1
kind: Secret
metadata:
  name: flashcards-db-credentials
  namespace: flashcards-prod
  labels:
    app: flashcards-sync
    env: production
type: kubernetes.io/basic-auth
stringData:
  username: app
  password: REPLACE_ME_WITH_RANDOM_PASSWORD
